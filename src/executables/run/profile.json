{
  "name": "run",
  "role": "primitive",
  "describe": "Implement a GitHub issue end-to-end: branch, code, commit, open PR.",
  "inputs": [
    {
      "name": "issue",
      "flag": "--issue",
      "type": "int",
      "required": true,
      "describe": "GitHub issue number to implement."
    },
    {
      "name": "base",
      "flag": "--base",
      "type": "string",
      "required": false,
      "describe": "Optional base branch override. Must match /^goal-[a-z0-9-]+$/; used by goal-tick so the feature branch forks from the shared goal branch and the PR targets it."
    }
  ],
  "claudeCode": {
    "model": "inherit",
    "permissionMode": "acceptEdits",
    "maxTurns": null,
    "systemPromptAppend": null,
    "tools": [
      "Read",
      "Write",
      "Edit",
      "Bash",
      "Grep",
      "Glob"
    ],
    "hooks": ["block-git"],
    "skills": [],
    "commands": [],
    "subagents": [],
    "plugins": [],
    "mcpServers": []
  },
  "cliTools": [],
  "scripts": {
    "preflight": [
      {
        "script": "setLifecycleLabel",
        "with": {
          "label": "kody:running",
          "color": "fbca04",
          "description": "kody: implementing the change"
        }
      },
      { "script": "runFlow" },
      { "script": "loadTaskState" },
      { "script": "resolveArtifacts" },
      { "script": "loadPriorArt" },
      { "script": "loadVaultContext" },
      { "script": "loadConventions" },
      { "script": "loadCoverageRules" },
      { "script": "composePrompt" }
    ],
    "postflight": [
      { "script": "parseAgentResult" },
      { "script": "requirePlanDeviations" },
      { "script": "verify" },
      { "script": "checkCoverageWithRetry" },
      { "script": "abortUnfinishedGitOps" },
      { "script": "commitAndPush" },
      { "script": "ensurePr", "runWhen": { "data.verifyOk": true } },
      { "script": "postIssueComment" },
      { "script": "writeRunSummary" },
      { "script": "saveTaskState" },
      { "script": "mirrorStateToPr" },
      { "script": "advanceFlow" }
    ]
  },
  "input": {
    "artifacts": [
      { "name": "plan", "required": false },
      { "name": "repro", "required": false },
      { "name": "repro.testPath", "required": false },
      { "name": "repro.failureSignature", "required": false }
    ]
  },
  "output": {
    "actionTypes": [
      "RUN_COMPLETED",
      "RUN_FAILED",
      "AGENT_NOT_RUN"
    ]
  }
}
